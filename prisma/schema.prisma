generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  LIVE
  DEVELOPMENT
  UPCOMING
  ARCHIVED
}

enum CourseStatus {
  AVAILABLE
  PREORDER
  WAITLIST
  DRAFT
}

enum ContactType {
  PARTNERSHIP
  CLIENT
  PRESS
  GENERAL
}

enum WallPostKind {
  THEORY
  COMMENT
  UPDATE
}

model SiteSection {
  id         String   @id @default(cuid())
  page       String
  key        String
  eyebrow    String?
  title      String
  body       String
  ctaLabel   String?
  ctaHref    String?
  order      Int      @default(0)
  accentJson Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([page, key])
  @@index([page, order])
}

model MentorshipOffer {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  summary      String
  description  String
  audience     String
  format       String
  deliverables Json
  differentiators Json
  ctaLabel     String
  ctaHref      String
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Course {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  excerpt     String
  description String
  status      CourseStatus @default(DRAFT)
  thumbnailUrl String?
  priceLabel  String?
  ctaLabel    String?
  ctaHref     String?
  waitlistUrl String?
  modules     Json
  bonuses     Json
  faq         Json
  featured    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, featured])
}

model Project {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  summary     String
  body        String
  category    String
  status      ProjectStatus @default(DEVELOPMENT)
  coverImage  String?
  accent      String?
  launchLabel String?
  featured    Boolean       @default(false)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, featured, sortOrder])
}

model Episode {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  series       String
  season       Int?
  actLabel     String?
  category     String?
  summary      String
  thumbnailUrl String?
  externalUrl  String?
  embedUrl     String?
  featured     Boolean  @default(false)
  publishedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([series, season, publishedAt])
}

model Testimonial {
  id         String   @id @default(cuid())
  name       String
  role       String?
  category   String
  quote      String
  sourceLabel String?
  featured   Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model BastilhaCharacter {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  title      String?
  allegiance String?
  summary    String
  imageUrl   String?
  featured   Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TimelineEvent {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  dateLabel  String
  body       String
  important  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WallPost {
  id         String       @id @default(cuid())
  kind       WallPostKind @default(COMMENT)
  title      String?
  body       String
  authorName String
  authorKey  String
  pinned     Boolean      @default(false)
  featured   Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  reactions  WallReaction[]
}

model WallReaction {
  id         String   @id @default(cuid())
  postId     String
  authorKey  String
  emoji      String
  createdAt  DateTime @default(now())

  post       WallPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, authorKey, emoji])
  @@index([postId])
}

model Poll {
  id          String       @id @default(cuid())
  title       String
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  options     PollOption[]
  votes       PollVote[]
}

model PollOption {
  id        String   @id @default(cuid())
  pollId    String
  label     String
  sortOrder Int      @default(0)

  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     PollVote[]

  @@index([pollId, sortOrder])
}

model PollVote {
  id         String   @id @default(cuid())
  pollId     String
  optionId   String
  authorKey  String
  createdAt  DateTime @default(now())

  poll       Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option     PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([pollId, authorKey])
  @@index([optionId])
}

model ContactSubmission {
  id         String      @id @default(cuid())
  name       String
  email      String
  company    String?
  type       ContactType @default(GENERAL)
  message    String
  status     String      @default("novo")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}
